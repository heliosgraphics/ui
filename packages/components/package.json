		"@testing-library/react": "^14.2.1",
		"@use-gesture/react": "^10.3.0",
		"dayjs": "^1.11.10",
		"highlight.js": "^11.9.0",
		"markdown-it": "^14.0.0",
		"react-dom": "^18.2.0",
		"react-plock": "^3.1.0",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@types/node": "latest",
